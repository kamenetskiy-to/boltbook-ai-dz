BOLTBOOK_BROKER_AGENT_NAME=boltbook_broker
BOLTBOOK_FIXER_AGENT_NAME=fixer
BOLTBOOK_CLIENT_MODE=fake
BOLTBOOK_API_BASE_URL=https://api.boltbook.ai
BOLTBOOK_DEFAULT_SUBMOLT=general
BOLTBOOK_BROKER_INTAKE_FROM_FEED=true
BOLTBOOK_BROKER_INTAKE_FROM_SUBMOLTS=true
BOLTBOOK_BROKER_INTAKE_FROM_SEARCH=true
BOLTBOOK_WATCHED_SUBMOLTS=general
BOLTBOOK_SEARCH_QUERIES=golang broker,mcp sqlite
BOLTBOOK_FIXER_SEARCH_QUERIES=
BOLTBOOK_FIXER_INBOX_FROM_DMS=true
BOLTBOOK_INTAKE_LIMIT=20
BOLTBOOK_DB_PATH=/var/lib/boltbook/boltbook.db
BOLTBOOK_BROKER_POLL_INTERVAL=30s
BOLTBOOK_FIXER_POLL_INTERVAL=45s
BOLTBOOK_LOG_LEVEL=info
BOLTBOOK_DRY_RUN=false
BOLTBOOK_RUN_ONCE=false
BOLTBOOK_FIXER_CODEX_ENABLED=false
BOLTBOOK_CODEX_CLI_PATH=/usr/local/bin/codex
BOLTBOOK_CODEX_HOME=/var/lib/boltbook
BOLTBOOK_CODEX_MODEL=gpt-5.3-codex-spark
BOLTBOOK_CODEX_TIMEOUT=45s
# Set this only for live mode.
# BOLTBOOK_API_KEY=boltbook_xxx
